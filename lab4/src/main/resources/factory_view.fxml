<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.UIController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Factory Monitor" style="-fx-font-weight: bold; -fx-font-size: 16px;" />

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="70.0" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints minWidth="50.0" />
        </columnConstraints>

        <Label text="Bodies" GridPane.rowIndex="0" />
        <ProgressBar fx:id="bodyBar" maxWidth="Infinity" progress="0.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Label fx:id="bodyLabel" text="0/0" GridPane.columnIndex="2" GridPane.rowIndex="0" />

        <Label text="Engines" GridPane.rowIndex="1" />
        <ProgressBar fx:id="engineBar" maxWidth="Infinity" progress="0.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Label fx:id="engineLabel" text="0/0" GridPane.columnIndex="2" GridPane.rowIndex="1" />

        <Label text="Accessories" GridPane.rowIndex="2" />
        <ProgressBar fx:id="accessoryBar" maxWidth="Infinity" progress="0.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <Label fx:id="accessoryLabel" text="0/0" GridPane.columnIndex="2" GridPane.rowIndex="2" />

        <Label text="Autos" GridPane.rowIndex="3" />
        <ProgressBar fx:id="autoBar" maxWidth="Infinity" progress="0.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <Label fx:id="autoLabel" text="0/0" GridPane.columnIndex="2" GridPane.rowIndex="3" />
    </GridPane>

    <VBox spacing="10.0">
        <Label text="Supplier Delay" />
        <Slider fx:id="supplierSlider" max="5000.0" min="100.0" value="1000.0" showTickLabels="true" />

        <Label text="Dealer Delay" />
        <Slider fx:id="dealerSlider" max="5000.0" min="100.0" value="1000.0" showTickLabels="true" />
    </VBox>

    <Label fx:id="tasksInQueueLabel" text="Tasks in Queue: 0" />
</VBox>